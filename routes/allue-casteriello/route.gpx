<?xml version="1.0" encoding="UTF-8"?><gpx creator="Wikiloc - http://www.wikiloc.com" version="1.1" xmlns="http://www.topografix.com/GPX/1/1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.topografix.com/GPX/1/1 http://www.topografix.com/GPX/1/1/gpx.xsd"><wpt lat="42.480974" lon="-0.307836"><ele>894.111</ele><name><![CDATA[Panorámica de Allué]]></name><cmt><![CDATA[Panorámica de Allué]]></cmt></wpt><wpt lat="42.481182" lon="-0.304028"><ele>901.312</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><wpt lat="42.481187" lon="-0.300545"><ele>910.339</ele><name><![CDATA[A la derecha]]></name><cmt><![CDATA[A la derecha]]></cmt></wpt><wpt lat="42.476616" lon="-0.297653"><ele>1013.167</ele><name><![CDATA[Yebra de Basa]]></name><cmt><![CDATA[Yebra de Basa]]></cmt></wpt><wpt lat="42.475683" lon="-0.297118"><ele>1017.703</ele><name><![CDATA[Atención. Dos hitos. Giro izquierda]]></name><cmt><![CDATA[Atención. Dos hitos. Giro izquierda]]></cmt></wpt><wpt lat="42.474491" lon="-0.300902"><ele>1146.78</ele><name><![CDATA[Haya. Fau]]></name><cmt><![CDATA[Haya. Fau]]></cmt></wpt><wpt lat="42.474147" lon="-0.301611"><ele>1172.189</ele><name><![CDATA[Flora]]></name><cmt><![CDATA[Flora]]></cmt></wpt><wpt lat="42.473383" lon="-0.301334"><ele>1179.313</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><wpt lat="42.473081" lon="-0.302544"><ele>1193.021</ele><name><![CDATA[Flora]]></name><cmt><![CDATA[Flora]]></cmt></wpt><wpt lat="42.472044" lon="-0.302879"><ele>1220.508</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><wpt lat="42.471436" lon="-0.30307"><ele>1235.45</ele><name><![CDATA[Panorámica]]></name><cmt><![CDATA[Panorámica]]></cmt></wpt><wpt lat="42.470795" lon="-0.304619"><ele>1298.224</ele><name><![CDATA[Panorámica]]></name><cmt><![CDATA[Panorámica]]></cmt></wpt><wpt lat="42.470779" lon="-0.304557"><ele>1299.157</ele><name><![CDATA[Punta de Portiello desde el Casteriello. Al fondo izquierda Peña Canciás]]></name><cmt><![CDATA[Punta de Portiello desde el Casteriello. Al fondo izquierda Peña Canciás]]></cmt></wpt><wpt lat="42.471264" lon="-0.304122"><ele>1281.793</ele><name><![CDATA[Sabiñánigo]]></name><cmt><![CDATA[Sabiñánigo]]></cmt></wpt><wpt lat="42.471128" lon="-0.304164"><ele>1280.776</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><wpt lat="42.468346" lon="-0.302733"><ele>1272.346</ele><name><![CDATA[Yebra de Basa]]></name><cmt><![CDATA[Yebra de Basa]]></cmt></wpt><wpt lat="42.465485" lon="-0.304373"><ele>1157.31</ele><name><![CDATA[Cruzamos brecha en Os Cabezales]]></name><cmt><![CDATA[Cruzamos brecha en Os Cabezales]]></cmt></wpt><wpt lat="42.465339" lon="-0.304595"><ele>1159.143</ele><name><![CDATA['Rayas' de Os Cabezales]]></name><cmt><![CDATA['Rayas' de Os Cabezales]]></cmt></wpt><wpt lat="42.464632" lon="-0.304859"><ele>1145.902</ele><name><![CDATA[Señalización en collado Os Cabezales]]></name><cmt><![CDATA[Señalización en collado Os Cabezales]]></cmt></wpt><wpt lat="42.465736" lon="-0.305591"><ele>1126.962</ele><name><![CDATA[Flora]]></name><cmt><![CDATA[Flora]]></cmt></wpt><wpt lat="42.466009" lon="-0.306678"><ele>1122.085</ele><name><![CDATA[Panorámica]]></name><cmt><![CDATA[Panorámica]]></cmt></wpt><wpt lat="42.471352" lon="-0.312365"><ele>1027.829</ele><name><![CDATA[Grandes masas forestales por Punta Poz0]]></name><cmt><![CDATA[Grandes masas forestales por Punta Poz0]]></cmt></wpt><wpt lat="42.472252" lon="-0.31289"><ele>1029.689</ele><name><![CDATA[Panorámica de Allué]]></name><cmt><![CDATA[Panorámica de Allué]]></cmt></wpt><wpt lat="42.472691" lon="-0.312494"><ele>1024.091</ele><name><![CDATA[Bosques de Puyaldo]]></name><cmt><![CDATA[Bosques de Puyaldo]]></cmt></wpt><wpt lat="42.476555" lon="-0.312723"><ele>900.646</ele><name><![CDATA[Cruce del barranco Senerol]]></name><cmt><![CDATA[Cruce del barranco Senerol]]></cmt></wpt><wpt lat="42.478015" lon="-0.3122"><ele>912.68</ele><name><![CDATA[A la derecha cuando alcancemos este sendero]]></name><cmt><![CDATA[A la derecha cuando alcancemos este sendero]]></cmt></wpt><wpt lat="42.479205" lon="-0.312614"><ele>919.064</ele><name><![CDATA[Panorámica]]></name><cmt><![CDATA[Panorámica]]></cmt></wpt><wpt lat="42.483297" lon="-0.311809"><ele>901.42</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><wpt lat="42.483372" lon="-0.31187"><ele>901.421</ele><name><![CDATA[Ruinas]]></name><cmt><![CDATA[Ruinas]]></cmt></wpt><wpt lat="42.484532" lon="-0.312163"><ele>898.478</ele><name><![CDATA[Foto]]></name><cmt><![CDATA[Foto]]></cmt></wpt><trk><name><![CDATA[Allué - Cerro Casteriello circular.]]></name><cmt><![CDATA[Salimos del aparcamiento de Allué y frente a él en la entrada del pueblo, sale una senda en descenso que nos llevaría a Yebra de Basa. En un tramo corto va a dar a una curva de la carretera por la que hemos subido con el coche. En ella sale un corto tramo de pista con cartel a "Yebra". Al llegar al barranco de Senerol sigue un poco más por la orilla y enseguida encontraremos un mojón para cruzar. Continuamos ahora por la otra orilla siguiendo los mojones y algunas marcas de PR que tras ascender por unas margas con roca llegamos a una senda que va por bosque todo el tiempo con zonas llanas o pequeños desniveles muy agradable.
Llegaremos a un cruce que nos lleva a Yebra de Basa a la izquierda y otro a la derecha con una marca de PR cruzada en x. Bien, pues abandonamos el sendero a Yebra y tomamos el de la derecha. Se trata de un camino en buena parte de suave ascenso y buena anchura, llega a un punto con un mojón a cada lado y ahí gira al sur y se endurece la pendiente. La vegetación es frondosa de pino royo, con boj, arce, roble e incluso un haya solitaria. Poco antes de la ascensión a la cumbre del Cerro Casteriello, se atraviesa una zona llana de viejos pinos. Los últimos metros son un poco más empinados.
Cuando el sendero llega a la zona más alta no podemos ver el paisaje por la vegetación pero a ambos lados se alzan unas rocas desde las que se puede ver ambos lados del paisaje.
Aquí es donde debemos tomar la decisión de bajar por el mismo sendero o continuar por él para hacer la ruta circular que nos ocupa.
Este sendero de descenso aunque es evidente seguirlo, no está tan pisado como el de subida y los mojones no están en "pié" en su mayoría pero como digo, no tiene dificultad seguirlo. 
A mitad de bajada llegamos al collado de Os Cabezales con unas largas paredes rocosas muy estéticas que aquí llamamos "rayas". Aquí se dividen las aguas del barranco San Antón y el Senerol y hay muchas indicaciones. Tomamos la que indica Allué por muy buen y antiguo sendero vamos bajando hasta el cauce del Senerol que no tiene dificultad ninguna de cruzar en condiciones de caudal normal.
Ahora tras un pequeño ascenso llegamos al sendero que nos lleva al punto de partida.]]></cmt><desc><![CDATA[Salimos del aparcamiento de Allué y frente a él en la entrada del pueblo, sale una senda en descenso que nos llevaría a Yebra de Basa. En un tramo corto va a dar a una curva de la carretera por la que hemos subido con el coche. En ella sale un corto tramo de pista con cartel a "Yebra". Al llegar al barranco de Senerol sigue un poco más por la orilla y enseguida encontraremos un mojón para cruzar. Continuamos ahora por la otra orilla siguiendo los mojones y algunas marcas de PR que tras ascender por unas margas con roca llegamos a una senda que va por bosque todo el tiempo con zonas llanas o pequeños desniveles muy agradable.
Llegaremos a un cruce que nos lleva a Yebra de Basa a la izquierda y otro a la derecha con una marca de PR cruzada en x. Bien, pues abandonamos el sendero a Yebra y tomamos el de la derecha. Se trata de un camino en buena parte de suave ascenso y buena anchura, llega a un punto con un mojón a cada lado y ahí gira al sur y se endurece la pendiente. La vegetación es frondosa de pino royo, con boj, arce, roble e incluso un haya solitaria. Poco antes de la ascensión a la cumbre del Cerro Casteriello, se atraviesa una zona llana de viejos pinos. Los últimos metros son un poco más empinados.
Cuando el sendero llega a la zona más alta no podemos ver el paisaje por la vegetación pero a ambos lados se alzan unas rocas desde las que se puede ver ambos lados del paisaje.
Aquí es donde debemos tomar la decisión de bajar por el mismo sendero o continuar por él para hacer la ruta circular que nos ocupa.
Este sendero de descenso aunque es evidente seguirlo, no está tan pisado como el de subida y los mojones no están en "pié" en su mayoría pero como digo, no tiene dificultad seguirlo. 
A mitad de bajada llegamos al collado de Os Cabezales con unas largas paredes rocosas muy estéticas que aquí llamamos "rayas". Aquí se dividen las aguas del barranco San Antón y el Senerol y hay muchas indicaciones. Tomamos la que indica Allué por muy buen y antiguo sendero vamos bajando hasta el cauce del Senerol que no tiene dificultad ninguna de cruzar en condiciones de caudal normal.
Ahora tras un pequeño ascenso llegamos al sendero que nos lleva al punto de partida.]]></desc><trkseg><trkpt lat="42.485003" lon="-.311948"><ele>876.081</ele><time>2022-09-02T09:41:23Z</time></trkpt><trkpt lat="42.485012" lon="-.312013"><ele>876.061</ele><time>2022-09-02T09:41:32Z</time></trkpt><trkpt lat="42.484994" lon="-.311937"><ele>876.017</ele><time>2022-09-02T09:41:35Z</time></trkpt><trkpt lat="42.485034" lon="-.311905"><ele>876.009</ele><time>2022-09-02T09:41:42Z</time></trkpt><trkpt lat="42.48507" lon="-.311867"><ele>890.879</ele><time>2022-09-02T09:41:46Z</time></trkpt><trkpt lat="42.485108" lon="-.311818"><ele>890.959</ele><time>2022-09-02T09:41:50Z</time></trkpt><trkpt lat="42.485155" lon="-.311777"><ele>891.510</ele><time>2022-09-02T09:41:54Z</time></trkpt><trkpt lat="42.485193" lon="-.311741"><ele>892.152</ele><time>2022-09-02T09:41:58Z</time></trkpt><trkpt lat="42.485213" lon="-.31168"><ele>892.296</ele><time>2022-09-02T09:42:03Z</time></trkpt><trkpt lat="42.485205" lon="-.311619"><ele>892.158</ele><time>2022-09-02T09:42:07Z</time></trkpt><trkpt lat="42.485243" lon="-.311584"><ele>892.193</ele><time>2022-09-02T09:42:13Z</time></trkpt><trkpt lat="42.485219" lon="-.311531"><ele>891.823</ele><time>2022-09-02T09:42:19Z</time></trkpt><trkpt lat="42.485265" lon="-.311563"><ele>889.694</ele><time>2022-09-02T09:42:27Z</time></trkpt><trkpt lat="42.485309" lon="-.311547"><ele>887.694</ele><time>2022-09-02T09:42:36Z</time></trkpt><trkpt lat="42.485292" lon="-.311487"><ele>880.557</ele><time>2022-09-02T09:42:41Z</time></trkpt><trkpt lat="42.485289" lon="-.311421"><ele>873.822</ele><time>2022-09-02T09:42:48Z</time></trkpt><trkpt lat="42.485269" lon="-.311364"><ele>869.909</ele><time>2022-09-02T09:42:57Z</time></trkpt><trkpt lat="42.485251" lon="-.311294"><ele>868.150</ele><time>2022-09-02T09:43:03Z</time></trkpt><trkpt lat="42.485206" lon="-.31125"><ele>863.550</ele><time>2022-09-02T09:43:09Z</time></trkpt><trkpt lat="42.485155" lon="-.311227"><ele>861.481</ele><t